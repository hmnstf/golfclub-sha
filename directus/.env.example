# ── Sicherheit ────────────────────────────────────────────────────────────────
SECRET="mindestens-32-zeichen-langer-zufälliger-schlüssel"

# ── Admin-Zugangsdaten ─────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@gc-sha.de"
ADMIN_PASSWORD="sicheres-passwort-hier"

# ── Datenbank (MySQL auf Plesk) ────────────────────────────────────────────────
DB_CLIENT="mysql"
DB_HOST="localhost"
DB_PORT="3306"
DB_DATABASE="gcsha_directus"
DB_USER="gcsha_user"
DB_PASSWORD="db-passwort-hier"

# ── URL ────────────────────────────────────────────────────────────────────────
PUBLIC_URL="https://cms.gc-sha.de"

# ── Extensions ────────────────────────────────────────────────────────────────
EXTENSIONS_PATH="./extensions"
MARKETPLACE_TRUST="all"

# ── CORS (erlaubt Zugriff von der Hauptdomain) ────────────────────────────────
CORS_ENABLED="true"
CORS_ORIGIN="https://gc-sha.de"

# ── Websockets ─────────────────────────────────────────────────────────────────
WEBSOCKETS_ENABLED="false"
