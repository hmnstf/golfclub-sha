# Directus CMS
# Lokal: http://localhost:8055 (kein Token nötig wenn public read erlaubt)
# Produktion: https://cms.gc-sha.de
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=

# Unsplash-Integration in Directus (Bilder direkt im CMS suchen)
# Kostenlosen API-Key holen: https://unsplash.com/developers → "New Application"
UNSPLASH_KEY=

# ── Kontaktformular: SMTP-Zugangsdaten für den Mailversand ───────────
# Vom E-Mail-Hoster/Provider des Golfclubs (z.B. All-Inkl, Ionos, Strato)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Optional: überschreibt den Directus-Feld "email" als Empfänger
CONTACT_EMAIL_TO=

# ── reCAPTCHA v3 (Kontaktformular-Spamschutz) ─────────────────────────
# Site Key liegt in Directus (settings.recaptcha_site_key, öffentlich).
# Secret Key NICHT in Directus – dort wäre er über die API auslesbar.
# Registrieren unter: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=
