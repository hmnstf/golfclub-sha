---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AccessibilityWidget from '../components/AccessibilityWidget.astro';
import { getSettings } from '../lib/directus';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Golfclub Schwäbisch Hall e.V.',
  description = 'Golfen in Schwäbisch Hall – Sport, Natur und Gemeinschaft erleben.',
  image = '/images/hero/course.jpg',
  structuredData,
} = Astro.props;

const settings = await getSettings();
const bildRundung = settings?.bild_rundung ?? 0;
const schriftgroesse = settings?.schriftgroesse ?? 16;

const fullTitle = `${title} | Golfclub Schwäbisch Hall`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);

// Seitenweite Schema.org-Identität (LocalBusiness/GolfCourse) – Adresse/Telefon
// entsprechen den echten Werten von /kontakt
const golfCourseSchema = {
  '@context': 'https://schema.org',
  '@type': 'GolfCourse',
  name: 'Golfclub Schwäbisch Hall e.V.',
  url: 'https://gc-sha.de',
  telephone: '+49 7907 8190',
  email: 'info@gc-sha.de',
  image: new URL('/images/hero/course.jpg', Astro.site).toString(),
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Am Golfplatz 1',
    postalCode: '74523',
    addressLocality: 'Schwäbisch Hall',
    addressCountry: 'DE',
  },
  sameAs: ['https://www.instagram.com/gc.schwaebischhall/'],
};

const structuredDataList = structuredData
  ? Array.isArray(structuredData) ? structuredData : [structuredData]
  : [];
---

<!doctype html>
<html lang="de" style={`font-size: ${schriftgroesse}px; --img-radius: ${bildRundung}px;`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph / Facebook, WhatsApp, etc. -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Golfclub Schwäbisch Hall" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter/X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />

    <!-- Schema.org strukturierte Daten -->
    <script type="application/ld+json" set:html={JSON.stringify(golfCourseSchema)} />
    {structuredDataList.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:bg-white focus:text-[#132e21] focus:px-4 focus:py-2 focus:z-50 focus:font-semibold">Zum Hauptinhalt springen</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <AccessibilityWidget />
  </body>
</html>
