---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AccessibilityWidget from '../components/AccessibilityWidget.astro';
import { getSettings } from '../lib/directus';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Golfclub Schwäbisch Hall e.V.',
  description = 'Golfen in Schwäbisch Hall – Sport, Natur und Gemeinschaft erleben.',
  image = '/images/hero/course.jpg',
} = Astro.props;

const settings = await getSettings();
const bildRundung = settings?.bild_rundung ?? 0;
const schriftgroesse = settings?.schriftgroesse ?? 16;

const fullTitle = `${title} | Golfclub Schwäbisch Hall`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="de" style={`font-size: ${schriftgroesse}px; --img-radius: ${bildRundung}px;`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Google Fonts: preconnect statt render-blockendem @import -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Open Graph / Facebook, WhatsApp, etc. -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Golfclub Schwäbisch Hall" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter/X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:bg-white focus:text-[#132e21] focus:px-4 focus:py-2 focus:z-50 focus:font-semibold">Zum Hauptinhalt springen</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <AccessibilityWidget />
  </body>
</html>
