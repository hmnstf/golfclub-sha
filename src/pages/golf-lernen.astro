---
import Layout from '../layouts/Layout.astro';
import { getSettings, bildUrlMitFormat } from '../lib/directus';

const settings = await getSettings();
const heroUrl = bildUrlMitFormat(settings?.bild_golf_lernen, { width: 1600, quality: 80 });
const trainingUrl = bildUrlMitFormat(settings?.bild_golf_lernen_training, { width: 1200, quality: 80 }) || heroUrl;
---

<Layout title="Golf Lernen – Golf Academy" description="Golf Academy Schwäbisch Hall – Platzreife, Einzelunterricht und Firmenevents mit Trainer Marco Melik">

  <!-- Hero -->
  <div class="relative h-[300px] md:h-[360px] overflow-hidden">
    <img src={heroUrl || "/images/gallery/golf2.jpg"} alt="Golf Lernen" class="absolute inset-0 w-full h-full object-cover"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/20 to-black/60"></div>
    <div class="absolute inset-0 flex flex-col justify-end pb-10 px-8 md:px-16 max-w-7xl mx-auto w-full">
      <p class="text-[#c4a94a] text-xs font-semibold uppercase tracking-widest mb-2">Golf Academy</p>
      <h1 class="font-serif text-4xl md:text-5xl text-white mb-3">Golf Lernen</h1>
      <p class="text-white/80 text-sm md:text-base max-w-lg mb-5">Der perfekte Einstieg – professionell, individuell und mit Freude.</p>
      <a href="#kurse" class="inline-block bg-[#c4a94a] text-[#132e21] font-semibold px-7 py-3 uppercase tracking-wider text-xs rounded-lg hover:bg-[#d4bc6a] transition-colors w-fit">
        Kurse entdecken
      </a>
    </div>
  </div>

  <!-- Ihr Weg zum Golf -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-[#c4a94a] text-xs font-semibold uppercase tracking-widest mb-3">Für jeden das Richtige</p>
        <h2 class="font-serif text-4xl text-[#132e21] mb-4">Ihr Weg zum Golf</h2>
        <p class="text-gray-500 max-w-2xl mx-auto text-sm leading-relaxed">
          Ob Einsteiger oder ambitionierter Spieler – bei uns finden Sie das passende Angebot,
          um Ihre Ziele zu erreichen. Unsere erfahrenen PGA Professionals begleiten Sie auf jedem Schritt.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            title: 'Schnuppergolf',
            desc: 'Golf unverbindlich ausprobieren und erste Schwünge erleben.',
            icon: 'M13 10V3L4 14h7v7l9-11h-7z',
            href: '#kurse',
            badge: 'Beliebtester Einstieg',
          },
          {
            title: 'Platzreife',
            desc: 'In wenigen Schritten zur DGV-Platzreife und bereit für den Platz.',
            icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
            href: '#kurse',
          },
          {
            title: 'Training',
            desc: 'Individuelles Training für jedes Spielniveau – technisch, taktisch, mental.',
            icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
            href: '#einzeltraining',
          },
          {
            title: 'Jugend & Kids',
            desc: 'Förderung mit Spaß und Bewegung – für die Golfer von morgen.',
            icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
            href: '#kurse',
          },
        ].map(({ title, desc, icon, href, badge }) => (
          <a href={href} class:list={[
            'group relative text-center p-6 border transition-all',
            badge ? 'border-[#c4a94a] shadow-md' : 'border-gray-100 hover:border-[#c4a94a] hover:shadow-sm',
          ]}>
            {badge && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#c4a94a] text-[#132e21] text-[10px] font-bold uppercase tracking-wider px-3 py-1 whitespace-nowrap">
                {badge}
              </span>
            )}
            <div class="w-14 h-14 rounded-full bg-[#f5f5f0] flex items-center justify-center mx-auto mb-4 group-hover:bg-[#c4a94a]/10 transition-colors">
              <svg class="w-7 h-7 text-[#c4a94a]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon}/>
              </svg>
            </div>
            <h3 class="font-serif text-xl text-[#132e21] mb-2">{title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-4">{desc}</p>
            <span class="text-xs font-bold uppercase tracking-widest text-[#c4a94a] group-hover:text-[#132e21] transition-colors">Mehr erfahren →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Unsere PGA Professionals -->
  <section class="py-20 bg-[#f5f5f0]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="mb-12">
        <p class="text-[#c4a94a] text-xs font-semibold uppercase tracking-widest mb-3">Ihr Team</p>
        <h2 class="font-serif text-4xl text-[#132e21]">Unsere PGA Professionals</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            name: 'Marco Melik',
            rolle: 'Head Golf Professional',
            desc: 'Als erfahrener Golf Professional begleitet Marco Melik Sie beim Erlernen und Verbessern Ihres Spiels. Sein praxisorientierter Ansatz macht jeden Unterricht zum Erlebnis.',
          },
          {
            name: 'Golf Academy',
            rolle: 'Gruppentraining & Platzreife',
            desc: 'Unsere Academy bietet strukturierte Gruppentrainings und Platzreife-Kurse für alle Altersgruppen. Gesellig, effektiv und preiswert.',
          },
          {
            name: 'Jugendförderung',
            rolle: 'Nachwuchsstützpunkt seit 2013',
            desc: 'Als anerkannter Nachwuchsstützpunkt bieten wir besondere Trainingsprogramme für junge Golfer und Talente – mit Spaß und sportlichem Ehrgeiz.',
          },
        ].map(({ name, rolle, desc }) => (
          <div class="bg-white p-8">
            <div class="w-16 h-16 rounded-full bg-[#132e21] flex items-center justify-center mb-5">
              <svg class="w-8 h-8 text-[#c4a94a]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <h3 class="font-serif text-xl text-[#132e21] mb-1">{name}</h3>
            <div class="text-[#c4a94a] text-xs font-semibold uppercase tracking-wider mb-4">{rolle}</div>
            <p class="text-gray-500 text-sm leading-relaxed mb-5">{desc}</p>
            <a href="/kontakt" class="text-xs font-bold uppercase tracking-widest text-[#132e21] hover:text-[#c4a94a] transition-colors">
              Kontakt aufnehmen →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Kursübersicht + FAQ -->
  <section id="kurse" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-[1fr_400px] gap-16">

      <!-- Kursübersicht -->
      <div>
        <p class="text-[#c4a94a] text-xs font-semibold uppercase tracking-widest mb-3">Termine 2025</p>
        <h2 class="font-serif text-4xl text-[#132e21] mb-8">Kursübersicht</h2>
        <div class="divide-y divide-gray-100">
          {[
            { titel: 'Platzreife Kurs',  datum: '15. – 19. Jun 2025', status: 'frei',   statusText: 'Freie Plätze' },
            { titel: 'Schnupperkurs',    datum: '22. Jun 2025',        status: 'frei',   statusText: 'Freie Plätze' },
            { titel: 'Aufbaukurs',       datum: '29. Jun – 13. Jul 2025', status: 'wenig', statusText: 'Wenige Plätze' },
            { titel: 'Damenkurs',        datum: '06. – 07. Jul 2025',  status: 'frei',   statusText: 'Freie Plätze' },
            { titel: 'Jugendcamp',       datum: '05. – 09. Aug 2025',  status: 'frei',   statusText: 'Freie Plätze' },
          ].map(({ titel, datum, status, statusText }) => (
            <div class="flex items-center justify-between py-4 gap-4">
              <div class="flex items-center gap-4 min-w-0">
                <svg class="w-4 h-4 text-[#c4a94a] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <div>
                  <div class="font-medium text-[#132e21] text-sm">{titel}</div>
                  <div class="text-gray-400 text-xs mt-0.5">{datum}</div>
                </div>
              </div>
              <span class={`shrink-0 text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 ${status === 'frei' ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700'}`}>
                {statusText}
              </span>
            </div>
          ))}
        </div>
        <a href="/kontakt" class="mt-6 inline-block text-xs font-bold uppercase tracking-widest text-[#c4a94a] hover:text-[#132e21] transition-colors">
          Zum Kurskalender →
        </a>
      </div>

      <!-- Gut zu wissen / FAQ -->
      <div>
        <p class="text-[#c4a94a] text-xs font-semibold uppercase tracking-widest mb-3">Häufige Fragen</p>
        <h2 class="font-serif text-4xl text-[#132e21] mb-8">Gut zu wissen</h2>
        <div class="space-y-2" id="faq-list">
          {[
            { frage: 'Wie lange dauert es bis zur Platzreife?', antwort: 'In der Regel 2–4 Wochen je nach Kursformat. Unsere Intensivkurse dauern 5 Tage.' },
            { frage: 'Was brauche ich zum Start?', antwort: 'Gar nichts – Schläger können geliehen werden. Bequeme Sportkleidung reicht vollkommen aus.' },
            { frage: 'Kann ich auch ohne Vorkenntnisse starten?', antwort: 'Selbstverständlich. Unsere Schnupperkurse und Platzreifekurse sind explizit für Anfänger konzipiert.' },
            { frage: 'Wie melde ich mich zu einem Kurs an?', antwort: 'Per Telefon unter +49 7907 8190 oder über unser Kontaktformular. Wir beraten Sie gerne persönlich.' },
          ].map(({ frage, antwort }, i) => (
            <div class="border border-gray-100 faq-item">
              <button class="w-full flex items-center justify-between px-5 py-4 text-left faq-btn" data-index={i}>
                <span class="font-medium text-[#132e21] text-sm pr-4">{frage}</span>
                <svg class="w-4 h-4 text-[#c4a94a] shrink-0 faq-icon transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="faq-answer hidden px-5 pb-4">
                <p class="text-gray-500 text-sm leading-relaxed">{antwort}</p>
              </div>
            </div>
          ))}
        </div>
        <a href="/kontakt" class="mt-6 inline-block text-xs font-bold uppercase tracking-widest text-[#c4a94a] hover:text-[#132e21] transition-colors">
          Alle Fragen ansehen →
        </a>
      </div>
    </div>
  </section>

  <!-- Individuelles Training -->
  <section id="einzeltraining" class="grid md:grid-cols-2 min-h-[380px]">
    <!-- Bild links -->
    <div class="relative min-h-[240px] md:min-h-0 overflow-hidden">
      <img src={trainingUrl || "/images/gallery/golf2.jpg"} alt="Individuelles Training" class="absolute inset-0 w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-black/30"></div>
    </div>
    <!-- Text rechts -->
    <div class="bg-[#f5f5f0] flex items-center">
      <div class="p-10 md:p-14">
        <p class="text-[#c4a94a] text-xs font-semibold uppercase tracking-widest mb-3">1:1 Betreuung</p>
        <h2 class="font-serif text-3xl text-[#132e21] mb-4">Individuelles Training</h2>
        <p class="text-gray-600 text-sm leading-relaxed mb-8">
          Sie möchten gezielt an Ihrem Spiel arbeiten? Buchen Sie eine Einzelstunde oder ein
          individuelles Coaching mit unseren PGA Professionals – mit Videoanalyse und persönlichem Trainingsplan.
        </p>
        <a
          href="/kontakt"
          class="inline-block bg-[#132e21] text-white font-semibold px-8 py-3 uppercase tracking-wider text-sm rounded-lg hover:bg-[#c4a94a] hover:text-[#132e21] transition-colors"
        >
          Training buchen
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#132e21] py-16">
    <div class="max-w-7xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-5">
        <svg class="w-10 h-10 text-[#c4a94a] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <div>
          <div class="font-serif text-2xl text-white mb-1">Fragen oder Beratung gewünscht?</div>
          <div class="text-white/60 text-sm">Wir beraten Sie gerne persönlich.</div>
        </div>
      </div>
      <a
        href="/kontakt"
        class="shrink-0 border border-white/40 text-white px-8 py-3 font-semibold uppercase tracking-wider text-sm rounded-lg hover:border-[#c4a94a] hover:text-[#c4a94a] transition-colors"
      >
        Kontakt aufnehmen →
      </a>
    </div>
  </section>

</Layout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const icon = btn.querySelector('.faq-icon');
      const isOpen = !answer?.classList.contains('hidden');
      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(i => i.classList.remove('rotate-180'));
      if (!isOpen) {
        answer?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
      }
    });
  });
</script>
