---
import Layout from '../layouts/Layout.astro';
import { getSeitenbilder, bildUrlMitFormat } from '../lib/directus';

const seitenbilder = await getSeitenbilder();
const heroUrl = bildUrlMitFormat(seitenbilder?.golf_lernen_hero, { width: 1600, quality: 80 });
---

<Layout title="Golf Lernen – Golf Academy" description="Golf Academy Schwäbisch Hall – Platzreife, Einzelunterricht und Firmenevents mit Trainer Marco Melik">

  <div class="relative h-[300px] md:h-[360px] overflow-hidden">
    <img src={heroUrl || "/images/gallery/golf2.jpg"} alt="Golf Lernen" class="absolute inset-0 w-full h-full object-cover"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/20 to-black/60"></div>
    <div class="absolute inset-0 flex flex-col justify-end pb-10 px-8 md:px-16 max-w-7xl mx-auto w-full">
      <p class="text-[#c4a94a] text-xs font-semibold uppercase tracking-widest mb-2">Golf Academy</p>
      <h1 class="font-serif text-4xl md:text-5xl text-white">Golf Lernen</h1>
    </div>
  </div>

  <!-- Trainer -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-[#c4a94a] text-xs font-semibold uppercase tracking-widest mb-3">Ihr Ansprechpartner</p>
        <h2 class="font-serif text-4xl text-[#132e21] mb-2">Marco Melik</h2>
        <div class="text-[#c4a94a] text-sm font-medium uppercase tracking-wider mb-6">Head Golf Professional</div>
        <p class="text-gray-600 leading-relaxed mb-4">
          Als erfahrener Golf Professional steht Marco Melik Ihnen beim Erlernen und Verbessern
          Ihres Spiels zur Seite. Sein praxisorientierter Ansatz und seine motivierende Art
          machen jeden Unterricht zum Erlebnis – egal ob Anfänger oder fortgeschrittener Spieler.
        </p>
        <p class="text-gray-600 leading-relaxed mb-8">
          Die Golf Academy verfügt über eine moderne Übungsanlage mit Driving Range,
          Putting Green und Short Game Area – ideale Voraussetzungen für effektives Training.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/kontakt"
            class="bg-[#c4a94a] text-[#132e21] font-semibold px-8 py-3 uppercase tracking-wider text-sm hover:bg-[#d4bc6a] transition-colors"
          >
            Kurs anfragen
          </a>
          <a
            href="tel:+4979078190"
            class="border border-[#132e21] text-[#132e21] font-semibold px-8 py-3 uppercase tracking-wider text-sm hover:border-[#c4a94a] hover:text-[#c4a94a] transition-colors"
          >
            +49 7907 8190
          </a>
        </div>
      </div>
      <div class="bg-[#f5f5f0] p-10 relative">
        <div class="w-12 h-0.5 bg-[#c4a94a] mb-6"></div>
        <blockquote class="font-serif text-xl text-[#132e21] leading-relaxed italic">
          „Golf verbindet sportliche Herausforderung mit Naturgenuss – es ist nie zu spät, damit anzufangen."
        </blockquote>
        <div class="mt-6 text-xs text-gray-400 uppercase tracking-wider">– Marco Melik, Golf Pro</div>
      </div>
    </div>
  </section>

  <!-- Kursangebote -->
  <section class="py-20 bg-[#f5f5f0]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="mb-12">
        <p class="text-[#c4a94a] text-xs font-semibold uppercase tracking-widest mb-3">Angebote</p>
        <h2 class="font-serif text-4xl text-[#132e21]">Kurse & Training</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            title: 'Schnupperkurs',
            subtitle: 'Der Einstieg in den Golfsport',
            desc: 'Lernen Sie Golf in einem entspannten Umfeld kennen – ohne Vorkenntnisse, ohne eigene Ausrüstung. Ideal für Neugierige und Einsteiger.',
            icon: 'M13 10V3L4 14h7v7l9-11h-7z',
          },
          {
            title: 'Platzreife',
            subtitle: 'Grundlage für den Golfsport',
            desc: 'In mehrwöchigen Kursen erlernen Sie die Grundlagen des Golfspiels und erwerben die Platzreife (DGV-Platzreife). Kurse starten regelmäßig.',
            icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
          },
          {
            title: 'Einzelunterricht',
            subtitle: 'Persönliche Betreuung durch den Pro',
            desc: 'Gezieltes Training für individuelle Stärken und Schwächen. Ideal für Spieler, die schnell Fortschritte erzielen möchten – mit Videoanalyse.',
            icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
          },
          {
            title: 'Gruppentraining',
            subtitle: 'Gemeinsam besser werden',
            desc: 'Regelmäßige Gruppentrainings für alle Spielstärken. Gesellig, effektiv und preiswert – Golf lernt sich am besten in guter Gemeinschaft.',
            icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
          },
          {
            title: 'Firmenevents',
            subtitle: 'Golf für Ihr Team',
            desc: 'Unvergessliche Teambuilding-Events auf unserem Platz. Vom Schnuppergolf bis zum firmeninternen Turnier – wir organisieren Ihren perfekten Golf-Tag.',
            icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
          },
          {
            title: 'Jugendtraining',
            subtitle: 'Förderung von klein auf',
            desc: 'Als anerkannter Nachwuchsstützpunkt seit 2013 bieten wir besondere Trainingsprogramme für junge Golfer und Talente.',
            icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
          },
        ].map(({ title, subtitle, desc, icon }) => (
          <div class="bg-white p-6 border-t-2 border-[#c4a94a]">
            <svg class="w-8 h-8 text-[#c4a94a] mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon}/>
            </svg>
            <h3 class="font-serif text-xl text-[#132e21] mb-1">{title}</h3>
            <div class="text-xs text-[#c4a94a] font-semibold uppercase tracking-wider mb-3">{subtitle}</div>
            <p class="text-gray-500 text-sm leading-relaxed mb-5">{desc}</p>
            <a href="/kontakt" class="text-xs font-bold uppercase tracking-widest text-[#132e21] hover:text-[#c4a94a] transition-colors">
              Anfragen →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Equipment / Werkstatt -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid md:grid-cols-2 gap-10">
      <div class="bg-[#f5f5f0] p-8">
        <p class="text-[#c4a94a] text-xs font-semibold uppercase tracking-widest mb-3">Pro Shop</p>
        <h3 class="font-serif text-2xl text-[#132e21] mb-3">Sporthaus Saemann</h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          Der Pro-Shop wird betrieben von Sporthaus Saemann GmbH & Co. KG.
          Hier finden Sie alles rund um die Golfausrüstung – von Schlägern bis zu Textilien.
        </p>
      </div>
      <div class="bg-[#f5f5f0] p-8">
        <p class="text-[#c4a94a] text-xs font-semibold uppercase tracking-widest mb-3">Werkstatt</p>
        <h3 class="font-serif text-2xl text-[#132e21] mb-3">Club-Repair mit Bill Guiney</h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          Gebrochene Schäfte, verschlissene Griffe, gelöste Schlägerköpfe –
          unsere Werkstatt unter Leitung von Bill Guiney repariert Ihre Schläger.
          Griffwechsel: 48-Stunden-Service, Sonderbestellungen in 72 Stunden.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#132e21] py-16">
    <div class="max-w-7xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <div class="font-serif text-2xl text-white mb-1">Bereit für Ihren ersten Schlag?</div>
        <div class="text-white/60 text-sm">Kontaktieren Sie uns unter +49 7907 8190</div>
      </div>
      <a
        href="/kontakt"
        class="shrink-0 bg-[#c4a94a] text-[#132e21] px-8 py-3 font-semibold uppercase tracking-wider text-sm hover:bg-[#d4bc6a] transition-colors"
      >
        Kurs anfragen
      </a>
    </div>
  </section>

</Layout>
