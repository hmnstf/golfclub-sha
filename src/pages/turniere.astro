---
import Layout from '../layouts/Layout.astro';
import { getEvents } from '../lib/directus';

const events = await getEvents();
const today = new Date().toISOString().split('T')[0];
const upcoming = events.filter(e => (e.datum_von ?? '') >= today);
const past = events.filter(e => (e.datum_von ?? '') < today).reverse();

const categoryColors: Record<string, string> = {
  turnier:    'bg-[#c4a94a] text-[#132e21]',
  club:       'bg-emerald-100 text-emerald-800',
  golfschule: 'bg-blue-100 text-blue-800',
  restaurant: 'bg-purple-100 text-purple-800',
  sonstiges:  'bg-gray-100 text-gray-700',
};

const categoryLabels: Record<string, string> = {
  turnier:    'Turnier',
  club:       'Clubveranstaltung',
  golfschule: 'Golfschule',
  restaurant: 'Restaurant',
  sonstiges:  'Sonstiges',
};

function formatDate(date: string, endDate?: string | null) {
  const d = new Date(date);
  const opts: Intl.DateTimeFormatOptions = { day: '2-digit', month: 'long', year: 'numeric' };
  if (!endDate) return d.toLocaleDateString('de-DE', opts);
  const e = new Date(endDate);
  if (d.getMonth() === e.getMonth() && d.getFullYear() === e.getFullYear()) {
    return `${d.getDate()}. – ${e.toLocaleDateString('de-DE', opts)}`;
  }
  return `${d.toLocaleDateString('de-DE', opts)} – ${e.toLocaleDateString('de-DE', opts)}`;
}
---

<Layout title="Turniere & Events" description="Alle Turniere und Veranstaltungen des Golfclub Schwäbisch Hall">
  <div class="bg-[#132e21] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <p class="text-[#c4a94a] text-sm font-medium uppercase tracking-widest mb-3">Programm</p>
      <h1 class="font-serif text-5xl text-white">Turniere & Events</h1>
    </div>
  </div>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">

      {upcoming.length > 0 ? (
        <>
          <h2 class="font-serif text-3xl text-[#132e21] mb-8">Kommende Veranstaltungen</h2>
          <div class="divide-y divide-gray-100" id="upcoming-list">
            {upcoming.map((event: any, i: number) => {
              const d = new Date(event.date);
              const cat = event.category ?? 'sonstiges';
              const id = `event-${i}`;
              return (
                <div class="event-item">
                  <!-- Klickbare Kopfzeile -->
                  <button
                    class="w-full flex items-center gap-5 py-5 text-left group"
                    aria-expanded="false"
                    data-target={id}
                  >
                    <!-- Datum-Badge -->
                    <div class="shrink-0 w-14 text-center">
                      <div class="font-serif text-3xl text-[#c4a94a] font-bold leading-none">{d.getDate()}</div>
                      <div class="text-gray-400 text-xs uppercase mt-0.5">
                        {d.toLocaleDateString('de-DE', { month: 'short' })}
                      </div>
                      <div class="text-gray-300 text-xs">{d.getFullYear()}</div>
                    </div>

                    <!-- Titel + Kategorie -->
                    <div class="flex-1 min-w-0">
                      <div class="flex flex-wrap items-center gap-2 mb-1">
                        <span class={`text-xs font-bold px-2 py-0.5 uppercase tracking-wide ${categoryColors[cat] ?? 'bg-gray-100 text-gray-700'}`}>
                          {categoryLabels[cat] ?? cat}
                        </span>
                        {event.location && (
                          <span class="text-xs text-gray-400 flex items-center gap-0.5">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            {event.location}
                          </span>
                        )}
                      </div>
                      <h3 class="font-serif text-xl text-[#132e21] group-hover:text-[#c4a94a] transition-colors">
                        {event.titel}
                      </h3>
                    </div>

                    <!-- Chevron -->
                    <svg class="chevron w-5 h-5 text-[#c4a94a] shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>

                  <!-- Aufklappbarer Inhalt -->
                  <div id={id} class="accordion-body hidden pb-6 pl-19">
                    <div class="ml-[4.75rem] border-l-2 border-[#c4a94a]/30 pl-6">
                      <dl class="grid sm:grid-cols-2 gap-x-8 gap-y-3 mb-5 text-sm">
                        <div>
                          <dt class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-0.5">Datum</dt>
                          <dd class="text-[#132e21]">{formatDate(event.date, event.endDate)}</dd>
                        </div>
                        {event.location && (
                          <div>
                            <dt class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-0.5">Ort</dt>
                            <dd class="text-[#132e21]">{event.location}</dd>
                          </div>
                        )}
                        <div>
                          <dt class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-0.5">Kategorie</dt>
                          <dd class="text-[#132e21]">{categoryLabels[cat] ?? cat}</dd>
                        </div>
                      </dl>

                      {event.description && (
                        <p class="text-gray-600 text-sm leading-relaxed mb-5">{event.description}</p>
                      )}

                      {event.registrationLink && (
                        <a
                          href={event.registrationLink}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-block bg-[#132e21] text-white text-xs font-bold uppercase tracking-wider px-5 py-2.5 hover:bg-[#c4a94a] hover:text-[#132e21] transition-colors"
                        >
                          Jetzt anmelden →
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </>
      ) : (
        <div class="text-center py-24">
          <svg class="w-16 h-16 mx-auto mb-4 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <p class="text-gray-400 text-lg font-medium mb-2">Keine anstehenden Veranstaltungen</p>
          <p class="text-gray-300 text-sm">Schauen Sie bald wieder vorbei.</p>
        </div>
      )}

      {past.length > 0 && (
        <div class="mt-16">
          <h2 class="font-serif text-xl text-gray-300 mb-4">Vergangene Veranstaltungen</h2>
          <div class="divide-y divide-gray-100 opacity-50">
            {past.slice(0, 5).map((event: any) => {
              const d = new Date(event.date);
              const cat = event.category ?? 'sonstiges';
              return (
                <div class="flex items-center gap-5 py-4">
                  <div class="shrink-0 w-14 text-center">
                    <div class="font-serif text-2xl text-gray-400">{d.getDate()}</div>
                    <div class="text-gray-300 text-xs uppercase">{d.toLocaleDateString('de-DE', { month: 'short' })}</div>
                  </div>
                  <div>
                    <div class="font-medium text-gray-500 text-sm">{event.titel}</div>
                    <div class="text-xs text-gray-400">{categoryLabels[cat] ?? cat}</div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}

    </div>
  </section>
</Layout>

<script>
  // Accordion-Logik
  document.querySelectorAll<HTMLButtonElement>('[data-target]').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.target!;
      const body = document.getElementById(targetId);
      const chevron = btn.querySelector('.chevron') as SVGElement | null;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Alle anderen schließen
      document.querySelectorAll('[data-target]').forEach(other => {
        if (other === btn) return;
        const otherId = (other as HTMLButtonElement).dataset.target!;
        const otherBody = document.getElementById(otherId);
        const otherChevron = other.querySelector('.chevron') as SVGElement | null;
        other.setAttribute('aria-expanded', 'false');
        otherBody?.classList.add('hidden');
        if (otherChevron) otherChevron.style.transform = '';
      });

      // Aktuellen togglen
      btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      body?.classList.toggle('hidden', isOpen);
      if (chevron) chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
    });
  });
</script>
