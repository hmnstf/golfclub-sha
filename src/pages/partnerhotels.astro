---
import Layout from '../layouts/Layout.astro';
import { getSettings, getPartnerhotels, bildUrl, bildUrlMitFormat } from '../lib/directus';

const [settings, hotels] = await Promise.all([getSettings(), getPartnerhotels()]);
const heroUrl = bildUrlMitFormat(settings?.bild_club, { width: 1600, quality: 80 });

// Tracking-Parameter anhängen, damit Partnerhotels sehen, dass der Besuch
// von unserer Website kommt
function mitTracking(url: string): string {
  try {
    const u = new URL(url);
    u.searchParams.set('utm_source', 'golfclub-sha');
    u.searchParams.set('utm_medium', 'referral');
    u.searchParams.set('utm_campaign', 'partnerhotels');
    return u.toString();
  } catch {
    return url;
  }
}
---

<Layout title="Partnerhotels" description="Übernachtungspartner des Golfclub Schwäbisch Hall für Gäste und Turnierteilnehmer">

  <!-- Hero -->
  <div class="relative h-[300px] md:h-[360px] overflow-hidden">
    <img src={heroUrl || "/images/gallery/golf1.jpg"} alt="Partnerhotels" class="absolute inset-0 w-full h-full object-cover"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/20 to-black/60"></div>
    <div class="absolute inset-0 flex flex-col justify-end pb-10 px-8 md:px-16 max-w-7xl mx-auto w-full">
      <p class="text-[#c4a94a] text-xs font-semibold uppercase tracking-widest mb-2">Für unsere Gäste</p>
      <h1 class="font-serif text-4xl md:text-5xl text-white">Partnerhotels</h1>
    </div>
  </div>

  <!-- Intro -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-gray-600 leading-relaxed">
        Für Ihren Aufenthalt in Schwäbisch Hall und Umgebung empfehlen wir Ihnen unsere Partnerhotels
        in der Region – ideal für Turnierteilnehmer, Gäste und alle, die einen Golfurlaub bei uns verbringen möchten.
      </p>
    </div>
  </section>

  <!-- Hotelliste -->
  <section class="pb-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {hotels.map((hotel: any) => (
          <div class="bg-[#f5f5f0] flex flex-col overflow-hidden">
            <div class="aspect-video overflow-hidden bg-gray-200">
              <img loading="lazy"
                src={bildUrlMitFormat(hotel.bild, { width: 600, height: 340, quality: 80 }) || '/images/gallery/golf1.jpg'}
                alt={hotel.name}
                class="w-full h-full object-cover"
              />
            </div>
            <div class="p-7 flex flex-col flex-1">
              <h2 class="font-serif text-xl text-[#132e21] mb-3">{hotel.name}</h2>
              <div class="text-sm text-gray-500 space-y-1 mb-4 flex-1">
                {hotel.adresse && <div>{hotel.adresse}</div>}
                {hotel.ort && <div>{hotel.ort}</div>}
                {hotel.telefon && <div class="mt-2">Tel.: <a href={`tel:${hotel.telefon.replace(/\s/g,'')}`} class="hover:text-[#c4a94a]">{hotel.telefon}</a></div>}
                {hotel.fax && <div>Fax: {hotel.fax}</div>}
                {hotel.email && <div>E-Mail: <a href={`mailto:${hotel.email}`} class="hover:text-[#c4a94a]">{hotel.email}</a></div>}
              </div>
              {hotel.website && (
                <a
                  href={mitTracking(hotel.website)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-xs font-bold uppercase tracking-widest text-[#c4a94a] hover:text-[#132e21] transition-colors"
                >
                  Zur Homepage
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
      {hotels.length === 0 && (
        <p class="text-center text-gray-400 text-sm">Aktuell sind keine Partnerhotels hinterlegt.</p>
      )}
    </div>
  </section>

</Layout>
