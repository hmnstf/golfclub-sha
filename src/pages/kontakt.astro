---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontakt" description="Kontaktieren Sie den Golfclub Schwäbisch Hall">
  <div class="bg-[#132e21] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <p class="text-[#c4a94a] text-sm font-medium uppercase tracking-widest mb-3">Anfahrt & Kontakt</p>
      <h1 class="font-serif text-5xl text-white">Wir sind für Sie da</h1>
    </div>
  </div>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-2 gap-16">
      <!-- Kontaktinfo -->
      <div>
        <h2 class="font-serif text-3xl text-[#132e21] mb-8">Kontaktdaten</h2>
        <div class="space-y-6 mb-10">
          {[
            {
              label: 'Adresse',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
              content: 'Am Golfplatz 1\n74523 Schwäbisch Hall',
            },
            {
              label: 'Telefon Sekretariat',
              icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
              content: '+49 7907 8190',
              href: 'tel:+4979078190',
            },
            {
              label: 'Telefon Restaurant',
              icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
              content: '+49 7907 94 02 42',
              href: 'tel:+49790794 0242',
            },
            {
              label: 'E-Mail',
              icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
              content: 'info@gc-sha.de',
              href: 'mailto:info@gc-sha.de',
            },
          ].map(({ label, icon, content, href }) => (
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-[#f5f5f0] flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#c4a94a]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon}/>
                </svg>
              </div>
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-0.5">{label}</div>
                {href ? (
                  <a href={href} class="text-[#132e21] hover:text-[#c4a94a] transition-colors whitespace-pre-line">{content}</a>
                ) : (
                  <div class="text-[#132e21] whitespace-pre-line">{content}</div>
                )}
              </div>
            </div>
          ))}
        </div>

        <!-- Google Maps (nur nach Cookie-Zustimmung) -->
        <div class="aspect-video border border-gray-200 overflow-hidden mb-6 relative bg-[#f5f5f0]">
          <div id="maps-placeholder" class="absolute inset-0 flex flex-col items-center justify-center gap-4 p-6 text-center">
            <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <p class="text-sm text-gray-400 max-w-xs">Google Maps ist deaktiviert. Bitte akzeptieren Sie die Cookies, um die Karte zu sehen.</p>
            <button id="maps-consent-btn" class="bg-[#132e21] text-white text-xs px-4 py-2 uppercase tracking-wider hover:bg-[#c4a94a] hover:text-[#132e21] transition-colors">
              Karte aktivieren
            </button>
          </div>
          <iframe
            id="maps-iframe"
            data-src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2601.5!2d9.7404!3d49.1128!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4798e6b0e9b1e1c7%3A0x1!2sGolfclub+Schw%C3%A4bisch+Hall!5e0!3m2!1sde!2sde!4v1"
            width="100%" height="100%" style="border:0; display:none;"
            allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            title="Golfclub Schwäbisch Hall auf Google Maps"
          ></iframe>
        </div>
        <script>
          function loadMap() {
            const iframe = document.getElementById('maps-iframe');
            const placeholder = document.getElementById('maps-placeholder');
            if (iframe && placeholder) {
              iframe.setAttribute('src', iframe.getAttribute('data-src') || '');
              iframe.style.display = 'block';
              placeholder.style.display = 'none';
            }
          }
          document.addEventListener('DOMContentLoaded', () => {
            if (window.CookieConsent?.acceptedCategory('maps')) loadMap();
            document.getElementById('maps-consent-btn')?.addEventListener('click', () => {
              window.CookieConsent?.acceptCategory('maps');
              loadMap();
            });
          });
          window.addEventListener('cc:onConsent', () => { if (window.CookieConsent?.acceptedCategory('maps')) loadMap(); });
          window.addEventListener('cc:onChange',  () => { if (window.CookieConsent?.acceptedCategory('maps')) loadMap(); });
        </script>
        <a
          href="https://maps.google.com/?q=Am+Golfplatz+1,+74523+Schwäbisch+Hall"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-[#132e21] hover:text-[#c4a94a] transition-colors mb-10"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          In Google Maps öffnen
        </a>

        <!-- Anfahrt -->
        <div id="anfahrt">
          <h2 class="font-serif text-2xl text-[#132e21] mb-6">Anfahrt</h2>
          <div class="space-y-4 text-sm text-gray-600">
            {[
              { von: 'B14 aus Richtung Stuttgart / Backnang', text: 'Durch Schwäbisch Hall bis Bausparkasse. Dort Richtung Vellberg/Ellwangen die L 1060. Nach ca. 11 km in Dörrenzimmern rechts zum Golfplatz.' },
              { von: 'A6 aus Richtung Heilbronn', text: 'Ausfahrt Schwäbisch Hall/Hessental. Auf der B19 Richtung Schwäbisch Hall. Links vor der Stadteinfahrt Richtung Vellberg über Erlach. Nach Vellberg rechts Richtung Schwäbisch Hall. Nach ca. 2 km links zum Golfplatz.' },
              { von: 'A6 aus Richtung Nürnberg', text: 'Ausfahrt Kirchberg nach Vellberg über Großaltdorf. Nach Vellberg rechts Richtung Schwäbisch Hall. Nach ca. 2 km links zum Golfplatz.' },
              { von: 'A7 aus Richtung Würzburg', text: 'Bis zum Autobahnkreuz Crailsheim/Feuchtwangen. Weiter wie Beschreibung „aus Richtung Nürnberg".' },
              { von: 'A7 aus Richtung Ulm', text: 'Ausfahrt Ellwangen. L 1060 in Richtung Schwäbisch Hall, über Rosenberg, Bühlertann und Vellberg. Nach ca. 2 km links zum Golfplatz.' },
            ].map(({ von, text }) => (
              <div class="p-4 bg-[#f5f5f0]">
                <div class="font-semibold text-[#132e21] mb-1 text-xs uppercase tracking-wide">{von}</div>
                <div>{text}</div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Kontaktformular / Mitgliedschaft -->
      <div>
        <h2 id="mitglied" class="font-serif text-3xl text-[#132e21] mb-2">Mitglied werden</h2>
        <p class="text-gray-500 text-sm mb-8">
          Interessieren Sie sich für eine Mitgliedschaft? Füllen Sie das Formular aus und wir melden uns schnellstmöglich bei Ihnen.
        </p>

        <form
          method="POST"
          action="/api/kontakt"
          class="space-y-5"
        >
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1.5" for="vorname">Vorname *</label>
              <input
                type="text"
                id="vorname"
                name="vorname"
                required
                class="w-full border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:border-[#c4a94a] transition-colors"
              />
            </div>
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1.5" for="nachname">Nachname *</label>
              <input
                type="text"
                id="nachname"
                name="nachname"
                required
                class="w-full border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:border-[#c4a94a] transition-colors"
              />
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1.5" for="email">E-Mail *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:border-[#c4a94a] transition-colors"
            />
          </div>
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1.5" for="telefon">Telefon</label>
            <input
              type="tel"
              id="telefon"
              name="telefon"
              class="w-full border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:border-[#c4a94a] transition-colors"
            />
          </div>
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1.5" for="interesse">Interesse</label>
            <select
              id="interesse"
              name="interesse"
              class="w-full border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:border-[#c4a94a] transition-colors bg-white"
            >
              <option value="">Bitte wählen</option>
              <option value="mitgliedschaft">Mitgliedschaft</option>
              <option value="greenfee">Greenfee / Gast</option>
              <option value="golfschule">Golfschule / Kurs</option>
              <option value="event">Veranstaltung / Event</option>
              <option value="sonstiges">Sonstiges</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1.5" for="nachricht">Nachricht</label>
            <textarea
              id="nachricht"
              name="nachricht"
              rows={5}
              class="w-full border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:border-[#c4a94a] transition-colors resize-none"
            ></textarea>
          </div>
          <div class="flex items-start gap-3">
            <input type="checkbox" id="datenschutz" name="datenschutz" required class="mt-0.5" />
            <label for="datenschutz" class="text-xs text-gray-500">
              Ich habe die <a href="/datenschutz" class="text-[#c4a94a] hover:underline">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zu. *
            </label>
          </div>
          <button
            type="submit"
            class="w-full bg-[#132e21] text-white py-3.5 text-sm font-semibold uppercase tracking-wider hover:bg-[#c4a94a] hover:text-[#132e21] transition-colors"
          >
            Anfrage senden
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
