---
import Layout from '../layouts/Layout.astro';

// Spielgruppen aus Keystatic laden
import spielgruppenData from '../content/spielgruppen/index.json';

const icons = [
  'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z',
  'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
];
const farben = ['#c4a94a', '#132e21'];

const gruppen = (spielgruppenData.gruppen ?? []).map((g: any, i: number) => ({
  name: g.name,
  icon: icons[i % icons.length],
  farbe: farben[i % farben.length],
  termine: g.termine ?? [],
  kontakt: {
    titel: g.ansprechpartner_titel ?? 'Ansprechpartner',
    name: g.ansprechpartner_name ?? '',
    telefon: g.telefon ?? '',
    email: g.email ?? '',
  },
  beschreibung: g.beschreibung ?? '',
}));
---

<Layout title="Spielgruppen" description="Spielgruppen des Golfclub Schwäbisch Hall – Ladies und Senioren">

  <div class="bg-[#132e21] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <p class="text-[#c4a94a] text-sm font-medium uppercase tracking-widest mb-3">Club</p>
      <h1 class="font-serif text-5xl text-white mb-4">Spielgruppen</h1>
      <p class="text-white/60 max-w-2xl">Golf mit Gleichgesinnten – unsere Spielgruppen treffen sich regelmäßig und bieten weit mehr als nur Golf.</p>
    </div>
  </div>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4">

      <!-- Intro -->
      <div class="max-w-3xl mb-14">
        <p class="text-gray-600 leading-relaxed text-lg">
          Zum Golfspielen unter Gleichgesinnten treffen sich unsere verschiedenen Spielgruppen regelmäßig. Die Aktivitäten gehen weit über das Spiel hinaus und beinhalten Freundschaftsspiele, Ausflüge, Besichtigungen und Vorträge. Selbst im Winter gibt es ein abwechslungsreiches Programm.
        </p>
        <p class="text-gray-500 mt-4 leading-relaxed">
          Neue Gesichter sind in allen Gruppen herzlich willkommen!
        </p>
      </div>

      <!-- Gruppen -->
      <div class="grid md:grid-cols-2 gap-8">
        {gruppen.map((gruppe) => (
          <div class="border border-gray-200 overflow-hidden">
            <!-- Header -->
            <div class="p-6 text-white" style={`background-color: ${gruppe.farbe}`}>
              <div class="flex items-center gap-3 mb-2">
                <svg class="w-6 h-6 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={gruppe.icon}/>
                </svg>
                <h2 class="font-serif text-2xl">{gruppe.name}</h2>
              </div>
            </div>

            <div class="p-6 space-y-6">
              <!-- Beschreibung -->
              <p class="text-gray-600 text-sm leading-relaxed">{gruppe.beschreibung}</p>

              <!-- Termine -->
              <div>
                <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">Spieltermine</h3>
                <div class="space-y-2">
                  {gruppe.termine.map((t) => (
                    <div class="flex gap-3 items-start text-sm">
                      <svg class="w-4 h-4 text-[#c4a94a] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                      </svg>
                      <div>
                        <div class="font-semibold text-[#132e21]">{t.uhrzeit}</div>
                        <div class="text-gray-400 text-xs">{t.saison}</div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Kontakt -->
              <div class="pt-4 border-t border-gray-100">
                <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">{gruppe.kontakt.titel}</h3>
                <div class="font-semibold text-[#132e21] mb-2">{gruppe.kontakt.name}</div>
                <div class="space-y-1 text-sm">
                  <a href={`tel:${gruppe.kontakt.telefon.replace(/\s/g, '')}`} class="flex items-center gap-2 text-gray-600 hover:text-[#c4a94a] transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    {gruppe.kontakt.telefon}
                  </a>
                  <a href={`mailto:${gruppe.kontakt.email}`} class="flex items-center gap-2 text-gray-600 hover:text-[#c4a94a] transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    {gruppe.kontakt.email}
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Mitmachen CTA -->
      <div class="mt-12 bg-[#f5f5f0] p-8 flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <div class="flex-1">
          <h3 class="font-serif text-xl text-[#132e21] mb-2">Interesse? Einfach vorbeikommen!</h3>
          <p class="text-gray-600 text-sm">Sie müssen sich nicht anmelden – kommen Sie einfach zum nächsten Spieltermin dazu und lernen Sie die Gruppe kennen.</p>
        </div>
        <a href="/kontakt" class="shrink-0 bg-[#132e21] text-white px-6 py-3 text-sm font-semibold uppercase tracking-wider hover:bg-[#c4a94a] hover:text-[#132e21] transition-colors">
          Kontakt aufnehmen
        </a>
      </div>

      <!-- Links -->
      <div class="mt-12 pt-8 border-t border-gray-100 flex flex-wrap gap-6">
        <a href="/club" class="text-sm font-medium text-[#132e21] hover:text-[#c4a94a] transition-colors">← Unser Club</a>
        <a href="/hole-in-one" class="text-sm font-medium text-[#132e21] hover:text-[#c4a94a] transition-colors">→ Hole-in-One</a>
        <a href="/clubmeister" class="text-sm font-medium text-[#132e21] hover:text-[#c4a94a] transition-colors">→ Clubmeister</a>
      </div>
    </div>
  </section>

</Layout>
