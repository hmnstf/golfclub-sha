---
import Layout from '../../layouts/Layout.astro';
import { getNews, bildUrl } from '../../lib/directus';

const alleNews = await getNews({ nurVeroeffentlicht: true, limit: 50 });

const kategorieLabel: Record<string, string> = {
  turnier:      '⛳ Turnier',
  ergebnis:     '🏆 Ergebnis',
  ankuendigung: '📣 Ankündigung',
  platz:        '🌿 Platz & Anlage',
  club:         '👥 Club',
  allgemein:    '📰 Allgemein',
};

function formatDatum(iso: string) {
  if (!iso) return '';
  const [y, m, d] = iso.split('-');
  return `${d}.${m}.${y}`;
}
---

<Layout title="News" description="Aktuelle Neuigkeiten vom Golfclub Schwäbisch Hall">

  <div class="bg-[#132e21] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <p class="text-[#c4a94a] text-sm font-medium uppercase tracking-widest mb-3">Aktuelles</p>
      <h1 class="font-serif text-5xl text-white mb-4">News</h1>
      <p class="text-white/60 max-w-2xl">Neuigkeiten, Ergebnisse und Berichte aus dem Golfclub Schwäbisch Hall.</p>
    </div>
  </div>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4">

      {alleNews.length === 0 ? (
        <div class="text-center py-24 text-gray-400">
          <svg class="w-16 h-16 mx-auto mb-4 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
          </svg>
          <p>Noch keine News vorhanden.</p>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 gap-8">
          {alleNews.map((artikel) => {
            const bild = bildUrl(artikel.bild);
            return (
              <a href={`/news/${artikel.slug}`} class="group flex flex-col border border-gray-100 hover:border-[#c4a94a]/40 transition-colors">
                {bild && (
                  <div class="overflow-hidden h-48">
                    <img
                      src={bild}
                      alt={artikel.titel}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  </div>
                )}
                <div class="p-6 flex flex-col flex-1">
                  <div class="flex items-center gap-3 mb-3">
                    <span class="text-xs font-semibold text-[#c4a94a] uppercase tracking-wider">
                      {kategorieLabel[artikel.kategorie] ?? artikel.kategorie}
                    </span>
                    <span class="text-xs text-gray-400">{formatDatum(artikel.datum)}</span>
                  </div>
                  <h2 class="font-serif text-xl text-[#132e21] mb-3 group-hover:text-[#c4a94a] transition-colors leading-snug">
                    {artikel.titel}
                  </h2>
                  {artikel.zusammenfassung && (
                    <p class="text-gray-500 text-sm leading-relaxed flex-1 line-clamp-3">
                      {artikel.zusammenfassung}
                    </p>
                  )}
                  <div class="mt-4 text-xs font-semibold text-[#132e21] group-hover:text-[#c4a94a] transition-colors uppercase tracking-wider">
                    Weiterlesen →
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>

</Layout>
