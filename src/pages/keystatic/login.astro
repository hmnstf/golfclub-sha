---
export const prerender = false;

const error = Astro.url.searchParams.get('error');
const from = Astro.url.searchParams.get('from') ?? '/keystatic';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verwaltung – GC Schwäbisch Hall</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Inter', sans-serif;
        background: #0d2118;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
      }
      .card {
        background: white;
        width: 100%;
        max-width: 400px;
        padding: 2.5rem;
      }
      .logo {
        display: flex;
        flex-direction: column;
        margin-bottom: 2rem;
      }
      .dots { display: flex; gap: 4px; margin-bottom: 6px; }
      .dot { width: 8px; height: 8px; background: #c4a94a; border-radius: 2px; }
      .logo-name { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: #132e21; line-height: 1.2; }
      .logo-sub { font-size: 0.75rem; color: #c4a94a; letter-spacing: 0.05em; }
      h1 { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: #132e21; margin-bottom: 0.25rem; }
      .subtitle { font-size: 0.8rem; color: #888; margin-bottom: 1.75rem; }
      label { display: block; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: #666; margin-bottom: 0.4rem; }
      input[type="password"] {
        width: 100%;
        border: 1px solid #ddd;
        padding: 0.7rem 1rem;
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.2s;
        margin-bottom: 1.25rem;
        font-family: 'Inter', sans-serif;
      }
      input[type="password"]:focus { border-color: #c4a94a; }
      .error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #b91c1c;
        font-size: 0.8rem;
        padding: 0.6rem 0.8rem;
        margin-bottom: 1rem;
      }
      button {
        width: 100%;
        background: #132e21;
        color: white;
        border: none;
        padding: 0.85rem;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        cursor: pointer;
        transition: background 0.2s;
        font-family: 'Inter', sans-serif;
      }
      button:hover { background: #c4a94a; color: #132e21; }
      .back { display: block; text-align: center; margin-top: 1.25rem; font-size: 0.75rem; color: #999; text-decoration: none; }
      .back:hover { color: #c4a94a; }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="logo">
        <div class="dots"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
        <div class="logo-name">Golfclub</div>
        <div class="logo-sub">Schwäbisch Hall</div>
      </div>
      <h1>Verwaltung</h1>
      <p class="subtitle">Bitte melden Sie sich an, um fortzufahren.</p>

      {error && <div class="error">Falsches Passwort. Bitte versuchen Sie es erneut.</div>}

      <form method="POST" action="/api/admin-login">
        <input type="hidden" name="from" value={from} />
        <div>
          <label for="password">Passwort</label>
          <input type="password" id="password" name="password" autofocus required placeholder="••••••••" />
        </div>
        <button type="submit">Anmelden</button>
      </form>
      <a href="/" class="back">← Zurück zur Website</a>
    </div>
  </body>
</html>
