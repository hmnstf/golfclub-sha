---
import Layout from '../layouts/Layout.astro';
import { resolveStatus } from '../lib/platzstatus';
import { getPlatzstatus, getPlatzstatusKalenderHeute, getPlatzstatusKalender, bildUrlMitFormat } from '../lib/directus';

const [rawStatus, kalenderHeute] = await Promise.all([
  getPlatzstatus(),
  getPlatzstatusKalenderHeute(),
]);
const heroUrl = bildUrlMitFormat(rawStatus?.hero_bild, { width: 1600, quality: 80 });

// Kalender-Override hat Vorrang vor Basis-Status
function getStatus(feld: string, basisWert: string): string {
  const kalWert = (kalenderHeute as any)?.[feld];
  if (kalWert) return kalWert;
  return basisWert ?? 'auto';
}

// Öffnungszeiten aus neuen Feldern
const zt = {
  hauptplatzOeffnet:     rawStatus?.hauptplatz_oeffnet      ?? '07:00',
  hauptplatzSchliesst:   rawStatus?.hauptplatz_schliesst    ?? '20:00',
  kurzplatzOeffnet:      rawStatus?.kurzplatz_oeffnet       ?? '07:00',
  kurzplatzSchliesst:    rawStatus?.kurzplatz_schliesst     ?? '21:00',
  drivingRangeOeffnet:   rawStatus?.driving_range_oeffnet   ?? '07:00',
  drivingRangeSchliesst: rawStatus?.driving_range_schliesst ?? '21:00',
  cafeOeffnet:           rawStatus?.cafe_oeffnet            ?? '09:00',
  cafeSchliesst:         rawStatus?.cafe_schliesst          ?? '21:00',
};

const resolved = {
  hauptplatz:   resolveStatus(getStatus('hauptplatz',   rawStatus?.hauptplatz   ?? 'auto'), zt.hauptplatzOeffnet,   zt.hauptplatzSchliesst),
  kurzplatz:    resolveStatus(getStatus('kurzplatz',    rawStatus?.kurzplatz    ?? 'auto'), zt.kurzplatzOeffnet,    zt.kurzplatzSchliesst),
  drivingRange: resolveStatus(getStatus('drivingRange', rawStatus?.drivingRange ?? 'auto'), zt.drivingRangeOeffnet, zt.drivingRangeSchliesst),
  cafe:         resolveStatus(getStatus('cafe',         rawStatus?.cafe         ?? 'auto'), zt.cafeOeffnet,         zt.cafeSchliesst),
  carts:        resolveStatus(getStatus('carts',        rawStatus?.carts        ?? 'open')),
};

// Kommende Einträge (nächste 14 Tage) für die Vorschau
const today = new Date().toISOString().split('T')[0];
const in14  = new Date(Date.now() + 14*24*60*60*1000).toISOString().split('T')[0];
const upcomingRaw = await getPlatzstatusKalender(today, in14);
const statusLabels: Record<string, string> = { open: 'Geöffnet', limited: 'Eingeschränkt', closed: 'Geschlossen' };
const upcoming = upcomingRaw
  .filter(s => s.datum !== today)
  .map(s => {
    const [y, m, d] = s.datum.split('-');
    const daysUntil = Math.round((new Date(s.datum).getTime() - Date.now()) / 86400000);
    return {
      ...s,
      datumFormatted: `${d}.${m}.${y}`,
      daysLabel: daysUntil === 0 ? 'Heute' : daysUntil === 1 ? 'Morgen' : `${d}.${m}.${y}`,
      hauptplatzLabel:   s.hauptplatz   ? statusLabels[s.hauptplatz]   : null,
      kurzplatzLabel:    s.kurzplatz    ? statusLabels[s.kurzplatz]    : null,
      drivingRangeLabel: s.drivingRange ? statusLabels[s.drivingRange] : null,
      cafeLabel:         s.cafe         ? statusLabels[s.cafe]         : null,
      cartsLabel:        s.carts        ? statusLabels[s.carts]        : null,
    };
  });

const statusMap: Record<string, { label: string; dot: string; bg: string; border: string }> = {
  open:    { label: 'Geöffnet',      dot: 'bg-emerald-500', bg: 'bg-white',    border: 'border-gray-100' },
  limited: { label: 'Eingeschränkt', dot: 'bg-amber-400',   bg: 'bg-amber-50', border: 'border-amber-200' },
  closed:  { label: 'Geschlossen',   dot: 'bg-red-500',     bg: 'bg-red-50',   border: 'border-red-200' },
};

const items = [
  { label: 'Meisterschaftsplatz (18 Loch)', status: resolved.hauptplatz,   oeffnet: zt.hauptplatzOeffnet,   schliesst: zt.hauptplatzSchliesst,  cartsMode: false },
  { label: 'Kurzplatz (6 Loch)',            status: resolved.kurzplatz,    oeffnet: zt.kurzplatzOeffnet,    schliesst: zt.kurzplatzSchliesst,   cartsMode: false },
  { label: 'Driving Range',                 status: resolved.drivingRange, oeffnet: zt.drivingRangeOeffnet, schliesst: zt.drivingRangeSchliesst, cartsMode: false },
  { label: 'Restaurant / Café Brassie',     status: resolved.cafe,         oeffnet: zt.cafeOeffnet,         schliesst: zt.cafeSchliesst,        cartsMode: false },
  { label: 'Carts / Elektrobuggys',         status: resolved.carts,        oeffnet: '',                     schliesst: '',                      cartsMode: true },
].map(item => ({
  ...item,
  ui: statusMap[item.status] ?? statusMap.open,
  displayLabel: item.cartsMode
    ? (item.status === 'open' ? 'Erlaubt' : 'Nicht erlaubt')
    : (statusMap[item.status] ?? statusMap.open).label,
}));

function formatDate(d: string) {
  const [y,m,day] = d.split('-');
  return `${day}.${m}.${y}`;
}
---

<Layout title="Platzstatus" description="Aktueller Platzstatus – Golfclub Schwäbisch Hall">
  <div class="relative h-[300px] md:h-[360px] overflow-hidden">
    <img src={heroUrl || "/images/gallery/golf1.jpg"} alt="Platzstatus" class="absolute inset-0 w-full h-full object-cover"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/20 to-black/60"></div>
    <div class="absolute inset-0 flex flex-col justify-end pb-10 px-8 md:px-16 max-w-7xl mx-auto w-full">
      <p class="text-[#c4a94a] text-xs font-semibold uppercase tracking-widest mb-2">Aktuell</p>
      <h1 class="font-serif text-4xl md:text-5xl text-white">Platzstatus</h1>
    </div>
  </div>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4">

      {rawStatus.hinweis && (
        <div class="mb-8 p-4 bg-amber-50 border border-amber-200 text-amber-800 text-sm rounded">
          <strong>📢 Hinweis:</strong> {rawStatus.hinweis}
        </div>
      )}

      <!-- Kalender-Override Banner (heute) -->
      {kalenderHeute && (
        <div class="mb-6 p-4 bg-amber-50 border border-amber-200 text-amber-800 text-sm flex items-start gap-3">
          <span class="text-lg">📅</span>
          <div>
            <strong>Tages-Status aktiv</strong>
            {kalenderHeute.hinweis && <span> – {kalenderHeute.hinweis}</span>}<br/>
            <span class="text-amber-700 text-xs">Status für heute manuell gesetzt</span>
          </div>
        </div>
      )}

      <!-- Status-Liste -->
      <div class="divide-y divide-gray-100 border border-gray-100">
        {items.map((item: any) => (
          <div class={`flex items-center justify-between px-6 py-4 ${item.ui.bg}`}>
            <div class="flex items-center gap-3">
              <span class={`w-2.5 h-2.5 rounded-full shrink-0 ${item.ui.dot}`}></span>
              <div>
                <span class="font-medium text-[#132e21] text-sm">{item.label}</span>
                {!item.cartsMode && item.oeffnet && (
                  <div class="text-xs text-gray-400 mt-0.5">Öffnungszeiten: {item.oeffnet} – {item.schliesst} Uhr</div>
                )}
              </div>
            </div>
            <span class="text-sm font-semibold text-gray-700 shrink-0">{item.displayLabel}</span>
          </div>
        ))}
      </div>

      <!-- Kommende Kalender-Einträge (nächste 14 Tage) -->
      {upcoming.length > 0 && (
        <div class="mt-12">
          <h2 class="font-serif text-2xl text-[#132e21] mb-6">Geplante Statusänderungen</h2>
          <div class="space-y-3">
            {upcoming.map((s: any) => (
              <div class="flex items-start gap-4 p-4 bg-[#f5f5f0] border border-gray-200">
                <div class="bg-[#132e21] text-white text-xs font-bold px-2 py-1 shrink-0 min-w-[80px] text-center">
                  {s.daysLabel}
                </div>
                <div>
                  <div class="font-medium text-[#132e21] text-sm">{s.hinweis || `Status ${s.datumFormatted}`}</div>
                  <div class="flex flex-wrap gap-2 mt-2">
                    {s.hauptplatzLabel   && <span class="text-xs px-2 py-0.5 bg-white border border-gray-200 text-gray-600">Hauptplatz: {s.hauptplatzLabel}</span>}
                    {s.kurzplatzLabel    && <span class="text-xs px-2 py-0.5 bg-white border border-gray-200 text-gray-600">Kurzplatz: {s.kurzplatzLabel}</span>}
                    {s.drivingRangeLabel && <span class="text-xs px-2 py-0.5 bg-white border border-gray-200 text-gray-600">Driving Range: {s.drivingRangeLabel}</span>}
                    {s.cafeLabel         && <span class="text-xs px-2 py-0.5 bg-white border border-gray-200 text-gray-600">Restaurant: {s.cafeLabel}</span>}
                    {s.cartsLabel        && <span class="text-xs px-2 py-0.5 bg-white border border-gray-200 text-gray-600">Carts: {s.cartsLabel}</span>}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <p class="text-xs text-gray-400 mt-8 text-center">
        Bei Fragen zum Platzstatus: <a href="tel:+4979078190" class="hover:text-[#132e21]">+49 7907 8190</a>
      </p>
    </div>
  </section>
</Layout>
