---
const year = new Date().getFullYear();
---

<footer class="bg-[#0d2118] text-white" aria-label="Seitenfußzeile">
  <!-- CTA Banner -->
  <div class="bg-[#132e21] py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <p class="text-[#c4a94a] text-sm font-medium uppercase tracking-widest mb-3">Gemeinschaft</p>
      <h2 class="font-serif text-3xl md:text-4xl text-white mb-6">
        Werden Sie Teil einer starken<br />Golfgemeinschaft in Schwäbisch Hall.
      </h2>
      <a
        href="/kontakt#mitglied"
        class="inline-block bg-[#c4a94a] text-[#132e21] font-semibold px-8 py-3 uppercase tracking-wider text-sm hover:bg-[#d4bc6a] transition-colors"
      >
        Mitgliedschaft entdecken
      </a>
    </div>
  </div>

  <!-- Footer Links -->
  <div class="border-t border-white/10 py-12">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Kontakt -->
      <div>
        <img
          src="/Logo-GC-SHA-1024x282-removebg.png"
          alt="Golfclub Schwäbisch Hall"
          class="h-10 w-auto mb-3 no-radius"
        />
        <address class="not-italic text-white/60 text-sm leading-relaxed">
          Am Golfplatz 1<br />
          74523 Schwäbisch Hall<br /><br />
          <a href="tel:+4979078190" class="hover:text-[#c4a94a] transition-colors">+49 7907 8190</a><br />
          <a href="tel:+4979079402 42" class="hover:text-[#c4a94a] transition-colors">+49 7907 94 02 42 (Restaurant)</a><br />
          <a href="mailto:info@gc-sha.de" class="hover:text-[#c4a94a] transition-colors">info@gc-sha.de</a>
        </address>
      </div>

      <!-- Club -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Club</h3>
        <ul class="space-y-2 text-white/60 text-sm">
          <li><a href="/club" class="hover:text-[#c4a94a] transition-colors">Unser Club</a></li>
          <li><a href="/historie" class="hover:text-[#c4a94a] transition-colors">Historie</a></li>
          <li><a href="/mannschaften" class="hover:text-[#c4a94a] transition-colors">Mannschaften</a></li>
          <li><a href="/spielgruppen" class="hover:text-[#c4a94a] transition-colors">Spielgruppen</a></li>
          <li><a href="/clubmeister" class="hover:text-[#c4a94a] transition-colors">Clubmeister</a></li>
          <li><a href="/hole-in-one" class="hover:text-[#c4a94a] transition-colors">Hole-in-One</a></li>
          <li><a href="/kontakt#mitglied" class="hover:text-[#c4a94a] transition-colors">Mitglied werden</a></li>
        </ul>
      </div>

      <!-- Golfanlage -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Golfanlage</h3>
        <ul class="space-y-2 text-white/60 text-sm">
          <li><a href="/golf-erleben" class="hover:text-[#c4a94a] transition-colors">Unsere Anlage</a></li>
          <li><a href="/spielgebuehren" class="hover:text-[#c4a94a] transition-colors">Spielgebühren</a></li>
          <li><a href="/platzregeln" class="hover:text-[#c4a94a] transition-colors">Platzregeln</a></li>
          <li><a href="/platzordnung" class="hover:text-[#c4a94a] transition-colors">Platz- & Spielordnung</a></li>
          <li><a href="/wettspielordnung" class="hover:text-[#c4a94a] transition-colors">Wettspielordnung</a></li>
          <li><a href="/hundeordnung" class="hover:text-[#c4a94a] transition-colors">Hundeordnung</a></li>
          <li><a href="/platzstatus" class="hover:text-[#c4a94a] transition-colors">Platzstatus</a></li>
          <li><a href="/golf-lernen" class="hover:text-[#c4a94a] transition-colors">Golf Academy</a></li>
          <li><a href="/restaurant" class="hover:text-[#c4a94a] transition-colors">Restaurant Brassie</a></li>
        </ul>
      </div>

      <!-- Service & Social -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Service</h3>
        <ul class="space-y-2 text-white/60 text-sm mb-6">
          <li><a href="https://www.pccaddie.net/clubs/0497729/app.php?cat=tt_timetable_course" target="_blank" rel="noopener noreferrer" class="hover:text-[#c4a94a] transition-colors">Startzeit buchen</a></li>
          <li><a href="/turniere" class="hover:text-[#c4a94a] transition-colors">Turnierkalender</a></li>
          <li><a href="/kontakt" class="hover:text-[#c4a94a] transition-colors">Kontakt & Anfahrt</a></li>
          <li><a href="/impressum" class="hover:text-[#c4a94a] transition-colors">Impressum</a></li>
          <li><a href="/datenschutz" class="hover:text-[#c4a94a] transition-colors">Datenschutz</a></li>
        </ul>
        <div class="flex gap-3">
          <a href="https://www.instagram.com/gc.schwaebischhall/" target="_blank" rel="noopener noreferrer" aria-label="Instagram @gc.schwaebischhall"
            class="w-8 h-8 bg-white/10 flex items-center justify-center hover:bg-[#c4a94a] transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>
        <p class="text-white/30 text-xs mt-2">@gc.schwaebischhall</p>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10 py-4 text-center text-white/40 text-xs">
    © {year} Golfclub Schwäbisch Hall e.V. · Alle Rechte vorbehalten
  </div>
</footer>
